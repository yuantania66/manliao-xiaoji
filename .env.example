# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/xinqing_dev?schema=public"

# Auth
SESSION_SECRET="replace-with-a-long-random-secret"
SESSION_EXPIRES_DAYS="30"

# WeChat mini program
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""

# AI provider
AI_PROVIDER="openai"
AI_MAIN_MODEL="gpt-4.1-mini"
AI_JUDGE_MODEL="gpt-4.1-mini"
AI_REWRITE_MODEL="gpt-4.1-mini"
OPENAI_API_KEY=""

# AI runtime
AI_TIMEOUT_MS="20000"
AI_MAX_REWRITE_ATTEMPTS="1"

# Uploads
UPLOAD_DIR="./public/uploads"
UPLOAD_PUBLIC_BASE_URL="http://localhost:3000/uploads"
MAX_NOTE_MEDIA_COUNT="9"
MAX_NOTE_IMAGE_SIZE_MB="10"

# App
APP_ENV="development"
NEXT_PUBLIC_APP_NAME="慢聊小记"
