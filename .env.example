# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/xinqing_dev?schema=public"

# Auth
SESSION_SECRET="replace-with-a-long-random-secret"
SESSION_EXPIRES_DAYS="30"

# WeChat mini program
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
ALLOW_WEB_MOCK_LOGIN="false"

# SMS provider: Tencent Cloud SMS
TENCENTCLOUD_SECRET_ID=""
TENCENTCLOUD_SECRET_KEY=""
TENCENT_SMS_REGION="ap-guangzhou"
TENCENT_SMS_SDK_APP_ID=""
TENCENT_SMS_SIGN_NAME=""
TENCENT_SMS_TEMPLATE_ID=""
TENCENT_SMS_TEMPLATE_ID_LOGIN=""
TENCENT_SMS_TEMPLATE_ID_CANCEL=""
SMS_CODE_TTL_MINUTES="5"

# AI provider
# Set AI_PROVIDER to "deepseek", "zhipu", "openai", or "mock".
AI_PROVIDER="deepseek"
AI_MAIN_MODEL="deepseek-v4-flash"
AI_JUDGE_MODEL="deepseek-v4-flash"
AI_REWRITE_MODEL="deepseek-v4-flash"
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
ZHIPU_API_KEY=""
ZHIPU_BASE_URL="https://open.bigmodel.cn/api/paas/v4"

# AI runtime
AI_TIMEOUT_MS="45000"
AI_MAX_REWRITE_ATTEMPTS="1"
GUEST_AI_IP_DAILY_LIMIT="20"

# Uploads
UPLOAD_DIR="./public/uploads"
UPLOAD_PUBLIC_BASE_URL="http://localhost:3000/uploads"
MAX_NOTE_MEDIA_COUNT="9"
MAX_NOTE_IMAGE_SIZE_MB="10"

# App
APP_ENV="development"
NEXT_PUBLIC_APP_NAME="慢聊小记"
