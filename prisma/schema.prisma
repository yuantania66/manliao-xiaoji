generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  CANCELLED
  BLOCKED
}

enum VerificationScene {
  LOGIN
  CANCEL_ACCOUNT
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageStatus {
  SAVED
  BLOCKED
  FALLBACK
  REWRITTEN
}

enum AiSourceType {
  CHAT
  NOTE_SLIP
  INSIGHT
}

enum AiGenerationStatus {
  GENERATED
  REWRITTEN
  FALLBACK
  FAILED
}

enum AiRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRISIS
}

enum EventSourceType {
  CHAT
  NOTE
  MANUAL
}

enum EventStatus {
  ACTIVE
  ENDED
  UNCLEAR
}

enum EventRelationType {
  TRIGGER
  RECOVERY
  AMPLIFY
  CONFLICT
  UNRELATED
}

enum UnderstandingSourceType {
  CHAT
  NOTE
}

enum HypothesisCategory {
  ATTACHMENT
  WORK
  FAMILY
  SELF
  RELATIONSHIP
  RECOVERY
  OTHER
}

enum HypothesisStatus {
  ACTIVE
  WEAKENED
  REJECTED
  MERGED
}

enum UnderstandingGraphNodeType {
  PERSON
  EVENT
  EMOTION
  TOPIC
  HYPOTHESIS
  VALUE
  COPING_METHOD
}

enum UnderstandingGraphEdgeType {
  TRIGGERED
  RELIEVED_BY
  RELATED_TO
  CONTRADICTS
  SUPPORTS
  REPEATED_IN
  BELONGS_TO_TIMELINE
}

model User {
  id                 String             @id @default(cuid())
  phone              String?            @unique
  wechatOpenid       String?            @unique
  nickname           String?
  avatarUrl          String?
  status             UserStatus         @default(ACTIVE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  sessions           Session[]
  verificationCodes  VerificationCode[]
  chatSessions       ChatSession[]
  chatMessages       ChatMessage[]
  notes              Note[]
  feedbacks          Feedback[]
  aiGenerations      AiGeneration[]
  aiJudgeResults     AiJudgeResult[]
  events             Event[]
  emotionSlices      EmotionSlice[]
  eventRelations     EventRelation[]
  facts              Fact[]
  experienceSlicesV2 ExperienceSlice[]
  interpretations    Interpretation[]
  hypotheses         Hypothesis[]
  graphNodes         UnderstandingGraphNode[]
  graphEdges         UnderstandingGraphEdge[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model VerificationCode {
  id         String            @id @default(cuid())
  userId     String?
  phone      String
  scene      VerificationScene
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime          @default(now())
  user       User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone, scene])
  @@index([expiresAt])
}

model ChatSession {
  id            String        @id @default(cuid())
  userId        String
  title         String?
  lastMessage   String?
  lastMessageAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String        @id @default(cuid())
  sessionId      String
  userId         String
  role           MessageRole
  content        String
  status         MessageStatus @default(SAVED)
  aiGenerationId String?
  createdAt      DateTime      @default(now())
  session        ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiGeneration   AiGeneration? @relation(fields: [aiGenerationId], references: [id], onDelete: SetNull)
  emotionSlices  EmotionSlice[]

  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
}

model Note {
  id                   String   @id @default(cuid())
  userId               String
  content              String
  moodName             String?
  moodIcon             String?
  mediaUrls            Json?
  recordDate           DateTime @db.Date
  coreEventIds         Json?
  emotionSliceIds      Json?
  generatedFromChatIds Json?
  isDraft              Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordDate])
  @@index([userId, createdAt])
}

model Fact {
  id              String                  @id @default(cuid())
  userId          String
  sourceType      UnderstandingSourceType
  sourceId        String
  occurredAt      DateTime?
  eventText       String
  people          Json?
  location        String?
  topics          Json?
  confidence      Float                   @default(0.5)
  createdAt       DateTime                @default(now())
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiences     ExperienceSlice[]
  interpretations Interpretation[]

  @@index([userId, occurredAt])
  @@index([userId, sourceType, sourceId])
  @@index([userId, createdAt])
}

model ExperienceSlice {
  id               String                  @id @default(cuid())
  userId           String
  sourceType       UnderstandingSourceType
  sourceId         String
  eventId          String?
  emotion          String?
  emotionIntensity Int?
  bodySignal       String?
  behavior         String?
  duration         String?
  createdAt        DateTime                @default(now())
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  event            Fact?                   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, emotion])
  @@index([eventId])
  @@index([userId, sourceType, sourceId])
}

model Interpretation {
  id                 String   @id @default(cuid())
  userId             String
  eventId            String
  interpretationText String
  evidenceText       String?
  confidence         Float    @default(0.5)
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event              Fact     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventId])
}

model Hypothesis {
  id                    String             @id @default(cuid())
  userId                String
  hypothesisText        String
  category              HypothesisCategory @default(OTHER)
  confidence            Float              @default(0.3)
  supportingEvidenceIds Json?
  counterEvidenceIds    Json?
  status                HypothesisStatus   @default(ACTIVE)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, category])
  @@index([userId, updatedAt])
}

model UnderstandingGraphNode {
  id         String                     @id @default(cuid())
  userId     String
  type       UnderstandingGraphNodeType
  label      String
  refId      String?
  properties Json?
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt
  user       User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromEdges  UnderstandingGraphEdge[]   @relation("UnderstandingGraphFrom")
  toEdges    UnderstandingGraphEdge[]   @relation("UnderstandingGraphTo")

  @@index([userId, type])
  @@index([userId, refId])
}

model UnderstandingGraphEdge {
  id         String                    @id @default(cuid())
  userId     String
  fromNodeId String
  toNodeId   String
  type       UnderstandingGraphEdgeType
  weight     Float                     @default(0.5)
  evidenceId String?
  createdAt  DateTime                  @default(now())
  user       User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromNode   UnderstandingGraphNode    @relation("UnderstandingGraphFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode     UnderstandingGraphNode    @relation("UnderstandingGraphTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([fromNodeId])
  @@index([toNodeId])
}

model Event {
  id               String            @id @default(cuid())
  userId           String
  title            String
  description      String?
  eventDate        DateTime          @db.Date
  startTime        DateTime?
  endTime          DateTime?
  sourceType       EventSourceType   @default(CHAT)
  sourceMessageIds Json?
  participants     Json?
  location         String?
  category         String?
  importanceScore  Float             @default(0)
  isCoreEvent      Boolean           @default(false)
  status           EventStatus       @default(UNCLEAR)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  emotionSlices    EmotionSlice[]
  fromRelations    EventRelation[]   @relation("EventRelationFrom")
  toRelations      EventRelation[]   @relation("EventRelationTo")

  @@index([userId, eventDate])
  @@index([userId, isCoreEvent])
  @@index([userId, createdAt])
}

model EmotionSlice {
  id              String       @id @default(cuid())
  userId          String
  eventId         String?
  date            DateTime     @db.Date
  time            DateTime?
  emotionType     String
  intensity       Int?
  valence         Float?
  arousal         Float?
  delta           Int?
  evidenceText    String?
  sourceMessageId String?
  createdAt       DateTime     @default(now())
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  event           Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  sourceMessage   ChatMessage? @relation(fields: [sourceMessageId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([eventId])
  @@index([sourceMessageId])
}

model EventRelation {
  id           String            @id @default(cuid())
  userId       String
  fromEventId  String
  toEventId    String
  relationType EventRelationType
  emotionType  String?
  strength     Float?
  evidenceText String?
  createdAt    DateTime          @default(now())
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromEvent    Event             @relation("EventRelationFrom", fields: [fromEventId], references: [id], onDelete: Cascade)
  toEvent      Event             @relation("EventRelationTo", fields: [toEventId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([fromEventId])
  @@index([toEventId])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  content   String
  contact   String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
}

model AiGeneration {
  id             String             @id @default(cuid())
  userId         String
  sessionId      String?
  sourceType     AiSourceType
  sourceId       String?
  model          String
  promptVersion  String
  inputText      String
  outputText     String
  rewriteOfId    String?
  latencyMs      Int?
  tokenInput     Int?
  tokenOutput    Int?
  status         AiGenerationStatus
  createdAt      DateTime           @default(now())
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       ChatMessage[]
  judgeResults   AiJudgeResult[]

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
  @@index([sourceType, sourceId])
}

model AiJudgeResult {
  id              String       @id @default(cuid())
  generationId    String
  userId          String
  passed          Boolean
  riskLevel       AiRiskLevel
  issues          Json
  rewriteRequired Boolean
  reason          String
  rawResult       Json?
  judgeModel      String
  promptVersion   String
  createdAt       DateTime     @default(now())
  generation      AiGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([generationId])
  @@index([userId, createdAt])
}
