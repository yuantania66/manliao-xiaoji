page {
  min-height: 100%;
  background: #fbf7f0;
  color: #2d2926;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  font: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  background: #fbf7f0;
  color: #2d2926;
  padding: 62rpx 44rpx 36rpx;
}

.status {
  position: fixed;
  left: 40rpx;
  top: 20rpx;
  z-index: 5;
  font-size: 22rpx;
  line-height: 32rpx;
  font-weight: 700;
  color: #2d2926;
}

.back {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  color: #71877b;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.fixed-back {
  position: fixed;
  left: 42rpx;
  top: 96rpx;
  z-index: 25;
}

.page-with-fixed-back {
  padding-top: 154rpx;
}

.eyebrow {
  color: #71877b;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 36rpx;
}

.title {
  color: #2d2926;
  font-size: 60rpx;
  font-weight: 700;
  line-height: 84rpx;
  letter-spacing: 0;
}

.body {
  color: #6d665f;
  font-size: 28rpx;
  line-height: 50rpx;
}

.muted {
  color: #a49a91;
}

.card {
  border-radius: 36rpx;
  background: #fffdf9;
}

.card-sage {
  border-radius: 36rpx;
  background: #e8f0ea;
}

.primary-button {
  height: 92rpx;
  border-radius: 30rpx;
  background: #71877b;
  color: #fffdf9;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 92rpx;
}

.secondary-button {
  height: 92rpx;
  border-radius: 30rpx;
  background: #fffdf9;
  color: #6d665f;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 92rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 140rpx;
  border-top: 1rpx solid #e8ded4;
  background: #fffdf9;
  display: flex;
  justify-content: space-around;
  align-items: center;
  overflow: hidden;
  font-size: 26rpx;
  font-weight: 700;
}

.bottom-indicator {
  position: absolute;
  left: 25%;
  top: 22rpx;
  width: 72rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #71877b;
  opacity: 0.96;
  transform: translateX(-50%);
  transition: left 180ms cubic-bezier(0.2, 0.8, 0.2, 1), width 180ms ease, opacity 180ms ease;
}

.bottom-bar.is-me .bottom-indicator {
  left: 75%;
}

.bottom-bar.is-switching .bottom-indicator {
  width: 84rpx;
  opacity: 1;
}

.bottom-item {
  position: relative;
  display: flex;
  width: 50%;
  height: 100%;
  align-items: center;
  justify-content: center;
  color: #a49a91;
  line-height: 140rpx;
  transition: color 160ms ease, opacity 160ms ease, transform 160ms ease;
}

.bottom-item.active {
  color: #2d2926;
  transform: translateY(-1rpx);
}

.bottom-bar.is-switching .bottom-item:not(.active) {
  opacity: 0.74;
}

.safe-bottom {
  height: 140rpx;
}
