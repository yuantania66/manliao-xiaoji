<view class="page search-page" style="padding-top: {{pageTop}}px;">
  <navigator url="/pages/chat/chat" class="close" style="top: {{closeTop}}px; right: {{closeRight}}px;" hover-class="none">×</navigator>
  <view class="eyebrow">聊聊</view>
  <view class="title">查找聊天内容</view>
  <view class="search-box">⌕<input value="{{query}}" bindinput="onInput" placeholder="输入查找内容" /></view>
  <view class="body help">可以搜索自己说过的话，也可以搜索新晴的回应。</view>
  <view wx:if="{{statusText}}" class="search-status">{{statusText}}</view>
  <view wx:if="{{showEmpty}}" class="result-card card">
    <view class="result-title">没有搜索结果</view>
    <view class="body">换一句更短的话试试。</view>
  </view>
  <view wx:for="{{results}}" wx:key="id" class="result-card card" data-id="{{item.id}}" data-session-id="{{item.sessionId}}" bindtap="openResult">
    <view class="result-title">{{item.text}}</view>
    <view class="body">{{item.timeLabel}}</view>
  </view>
</view>
