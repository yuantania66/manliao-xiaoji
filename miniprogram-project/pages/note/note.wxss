}

.slip-date {
  position: absolute;
  left: 24px;
  top: 52px;
  font-size: 11px;
  line-height: 18px;
  z-index: 3;
}

.slip-title {
  position: absolute;
  left: 24px;
  top: 116px;
  width: 260px;
  font-size: 20px;
  font-weight: 600;
  line-height: 31px;
  z-index: 3;
}

.slip-line {
  position: absolute;
  left: 24px;
  top: 220px;
  width: 266px;
  height: 1px;
  background: #e8ded4;
  z-index: 3;
}

.slip-body {
  position: absolute;
  left: 24px;
  top: 246px;
  width: 210px;
  max-height: 56px;
  overflow: hidden;
  border-radius: 16px;
  background: #e8f0ea;
  padding: 12px 16px;
  font-size: 13px;
  line-height: 22px;
  white-space: nowrap;
  text-overflow: ellipsis;
  z-index: 3;
}

.slip-brand {
  position: absolute;
  left: 24px;
  top: 348px;
  font-size: 13px;
  font-weight: 600;
  line-height: 20px;
  z-index: 3;
}

.slip-brand-note {
  position: absolute;
  left: 24px;
  top: 369px;
  font-size: 10px;
  line-height: 16px;
  z-index: 3;
}

.slip-qr {
  position: absolute;
  left: 230px;
  top: 326px;
  width: 46px;
  height: 46px;
  border-radius: 12px;
  background: rgba(255, 253, 249, 0.58);
  z-index: 3;
}

.qr-dot {
  position: absolute;
  width: 4px;
  height: 4px;
  border-radius: 1px;
  background: #71877b;
  opacity: 0.78;
}

.qr-dot-0 { left: 6px; top: 6px; }
.qr-dot-1 { left: 11px; top: 6px; }
.qr-dot-2 { left: 16px; top: 6px; }
.qr-dot-3 { left: 6px; top: 11px; }
.qr-dot-4 { left: 16px; top: 11px; }
.qr-dot-5 { left: 36px; top: 6px; }
.qr-dot-6 { left: 36px; top: 11px; }
.qr-dot-7 { left: 31px; top: 31px; }
.qr-dot-8 { left: 11px; top: 36px; }

.slip-share,
.slip-save {
  position: absolute;
  top: 498px;
  width: 150px;
  height: 46px;
  border-radius: 15px;
  font-size: 13px;
  font-weight: 600;
  line-height: 46px;
}

.slip-share {
  left: 20px;
  background: #fffdf9;
  color: #6d665f;
}

.slip-save {
  left: 184px;
  background: #71877b;
  color: #fffdf9;
}

.slip-continue {
  position: absolute;
  left: 120px;
  top: 620px;
  width: 120px;
  height: 20px;
