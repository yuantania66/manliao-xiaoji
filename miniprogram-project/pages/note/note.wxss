}

.slip-layer {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 30;
}

.slip-overlay {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(91, 83, 77, 0.5);
}

.slip-panel {
  position: absolute;
  left: 18px;
  top: 82px;
  width: 354px;
  height: 682px;
  border-radius: 24px;
  background: #fbf7f0;
}

.slip-kicker {
  position: absolute;
  left: 20px;
  top: 24px;
  font-size: 13px;
  font-weight: 600;
  line-height: 20px;
}

.slip-close {
  position: absolute;
  right: 16px;
  top: 20px;
  width: 32px;
  height: 32px;
  color: #a49a91;
  font-size: 22px;
  line-height: 32px;
}

.slip-card {
  position: absolute;
  left: 20px;
  top: 70px;
  width: 314px;
  height: 400px;
  overflow: hidden;
  border-radius: 20px;
  background: #fbf7f0;
}

.slip-paper {
  position: absolute;
  left: 24px;
  top: 18px;
  width: 266px;
  height: 364px;
  border-radius: 24px;
  background: #fffdf9;
}

.share-ticket::before,
.share-ticket::after {
  content: "";
  position: absolute;
  top: 188px;
  width: 32px;
  height: 32px;
  border-radius: 999px;
  background: #fbf7f0;
  z-index: 2;
}

.share-ticket::before {
  left: 10px;
}

.share-ticket::after {
  right: 10px;
}

.share-polaroid .slip-paper,
.share-postcard .slip-paper {
  left: 30px;
  top: 16px;
  width: 254px;
  height: 366px;
  border-radius: 18px;
}

.share-polaroid .slip-photo,
.share-postcard .slip-photo {
  display: block;
}

.share-envelope .slip-paper {
  top: 46px;
  height: 270px;
  border-radius: 22px;
}

.share-envelope .slip-paper::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 266px;
  height: 146px;
  border-radius: 22px 22px 0 0;
  background: linear-gradient(160deg, #f4e4d3 0 49%, transparent 50%),
    linear-gradient(200deg, #e8f0ea 0 49%, transparent 50%);
}

.share-film {
  background: #fbf7f0;
}

.share-film .slip-paper {
  left: 44px;
  top: 20px;
  width: 226px;
  height: 360px;
  border-radius: 18px;
  background: #2d2926;
}

.share-film .slip-title {
  color: #fffdf9;
}

.share-film .slip-brand-note,
.share-film .slip-date {
  color: #d8d0c8;
}

.share-receipt .slip-paper {
  left: 34px;
  top: 22px;
  width: 246px;
  height: 356px;
  border-radius: 18px;
}

.share-receipt::before,
.share-receipt::after {
  content: "";
  position: absolute;
  left: 38px;
  width: 238px;
  height: 16px;
  background-image: radial-gradient(circle, #fbf7f0 8px, transparent 9px);
  background-size: 18px 16px;
  z-index: 2;
}

.share-receipt::before {
  top: 12px;
}

.share-receipt::after {
  bottom: 12px;
}

.slip-photo {
  display: none;
  position: absolute;
  left: 48px;
  top: 42px;
  width: 218px;
  height: 175px;
  border-radius: 18px;
  background: #e4ecf0;
  z-index: 1;
}

.photo-tile {
  position: absolute;
  width: 50px;
  height: 78px;
  border-radius: 10px;
  opacity: 0.6;
}

.photo-tile-1 {
  left: 20px;
  top: 24px;
  background: #f4e4d3;
  transform: rotate(-16deg);
}

.photo-tile-2 {
  left: 82px;
  top: 44px;
  background: #e8f0ea;
  transform: rotate(8deg);
}

.photo-tile-3 {
  left: 140px;
  top: 24px;
  background: #f1d4c8;
}

.slip-accent {
  position: absolute;
  left: 24px;
  top: 28px;
  width: 34px;
  height: 4px;
  border-radius: 2px;
  background: #71877b;
