<view class="screen chat-screen">
  <view class="status">9:41</view>
  <button class="back-link" bindtap="goBack">‹ 返回</button>
  <button class="more" bindtap="toggleMenu">···</button>

  <view wx:if="{{menuOpen}}" class="mask" bindtap="closeMenu"></view>
  <view wx:if="{{menuOpen}}" class="overflow-menu">
    <text class="menu-item">♡ 聊天日历</text>
    <view class="divider"></view>
    <text class="menu-item second">⌕ 查找聊天内容</text>
  </view>

  <text class="chat-title">慢慢说。</text>
  <view class="leaf chat-leaf">
    <view class="leaf-stem"></view>
    <view class="leaf-branch"></view>
    <view class="leaf-bud one"></view>
    <view class="leaf-bud two"></view>
    <view class="leaf-bud three"></view>
  </view>

  <text wx:if="{{messages.length === 0}}" class="empty-copy">不用急。\n想说到哪里，就说到哪里。</text>

  <scroll-view class="message-list" scroll-y>
    <block wx:for="{{messages}}" wx:key="index">
      <view class="bubble {{item.role === 'user' ? 'user-bubble' : 'ai-bubble'}}">{{item.text}}</view>
    </block>
  </scroll-view>

  <view class="chat-input">
    <input class="chat-field" placeholder="说点什么。" value="{{input}}" bindinput="updateInput" confirm-type="send" bindconfirm="sendMessage" />
    <button class="send-button" bindtap="sendMessage">发送</button>
  </view>
  <view class="bottom-indicator"></view>
</view>
