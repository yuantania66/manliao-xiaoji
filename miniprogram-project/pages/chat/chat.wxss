.more {
  position: absolute;
  right: 22px;
  top: 78px;
  width: 40px;
  height: 22px;
  color: #71877b;
  font-size: 18px;
  font-weight: 600;
  line-height: 22px;
  z-index: 6;
}

.mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(251, 247, 240, 0.6);
  z-index: 4;
}

.overflow-menu {
  position: absolute;
  right: 22px;
  top: 108px;
  width: 194px;
  height: 126px;
  border-radius: 16px;
  background: #fffdf9;
  z-index: 5;
}

.menu-item {
  position: absolute;
  left: 22px;
  top: 24px;
  font-size: 14px;
  font-weight: 600;
  line-height: 22px;
}

.menu-item.second {
  top: 82px;
}

.divider {
  position: absolute;
  left: 20px;
  top: 63px;
  width: 154px;
  height: 1px;
  background: #e8ded4;
}

.chat-title {
  position: absolute;
  left: 22px;
  top: 118px;
  font-size: 30px;
  font-weight: 600;
  line-height: 40px;
}

.chat-leaf {
  left: 226px;
  top: 196px;
}

.chat-leaf::before {
  content: "";
  position: absolute;
  left: 28px;
  top: 24px;
  width: 110px;
  height: 110px;
  border-radius: 50%;
  background: #f4e4d3;
}

.empty-copy {
  position: absolute;
  left: 22px;
  top: 330px;
  white-space: pre-line;
  color: #9e9891;
  font-size: 24px;
  font-weight: 600;
  line-height: 38px;
}

.message-list {
  position: absolute;
  left: 22px;
  right: 22px;
  top: 220px;
  bottom: 112px;
}

.bubble {
  display: inline-block;
  max-width: 286px;
  margin-bottom: 14px;
  padding: 12px 16px;
  border-radius: 18px;
  font-size: 14px;
  line-height: 24px;
}

.user-bubble {
  margin-left: auto;
  background: #71877b;
  color: #fffdf9;
}

.ai-bubble {
  background: #fffdf9;
  color: #6d665f;
}

.chat-input {
  position: fixed;
  left: 22px;
  right: 22px;
  bottom: 48px;
  height: 58px;
  border-radius: 20px;
  background: #fffdf9;
}

.chat-field {
  position: absolute;
  left: 20px;
  right: 88px;
  top: 0;
  height: 58px;
  color: #6d665f;
  font-size: 14px;
}

.send-button {
  position: absolute;
  right: 10px;
  top: 8px;
  width: 64px;
  height: 42px;
  border-radius: 16px;
  background: #71877b;
  color: #fffdf9;
  font-size: 14px;
  font-weight: 600;
  line-height: 42px;
}
