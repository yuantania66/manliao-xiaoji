.chat-page {
  padding-bottom: 150rpx;
  overflow: hidden;
}

.chat-back {
  position: fixed;
  left: 42rpx;
  top: 96rpx;
  z-index: 25;
}

.chat-title {
  position: fixed;
  left: 42rpx;
  top: 174rpx;
  width: 520rpx;
  font-size: 54rpx;
  font-weight: 600;
  line-height: 73rpx;
}

.menu-button {
  position: fixed;
  top: 188rpx;
  right: 42rpx;
  z-index: 20;
  width: 77rpx;
  height: 42rpx;
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: #71877b;
  font-size: 35rpx;
  font-weight: 600;
  line-height: 42rpx;
  text-align: center;
}

.menu-button::after {
  border: 0;
}

.menu-layer {
  position: fixed;
  inset: 0;
  z-index: 30;
  background: rgba(251, 247, 240, 0.52);
}

.chat-menu {
  position: fixed;
  top: 250rpx;
  right: 42rpx;
  z-index: 40;
  width: 373rpx;
  height: 190rpx;
  box-sizing: border-box;
  border-radius: 31rpx;
  background: #fffdf9;
  padding: 24rpx 40rpx 19rpx;
  color: #2d2926;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  height: 56rpx;
  color: #2d2926;
}

.menu-item text {
  display: block;
  margin-left: 22rpx;
  height: 38rpx;
  line-height: 38rpx;
}

.menu-icon {
  position: relative;
  flex: 0 0 30rpx;
  width: 30rpx;
  height: 30rpx;
  color: #2d2926;
}

.menu-icon-image {
  display: block;
  width: 30rpx;
  height: 30rpx;
}

.menu-line {
  height: 1rpx;
  margin: 13rpx 0;
  background: #e8ded4;
}

.messages {
  position: fixed;
  left: 42rpx;
  top: 312rpx;
  width: 673rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  padding-right: 0;
}

.mode-notice {
  box-sizing: border-box;
  width: 100%;
  margin: 0 0 24rpx;
  padding: 18rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 249, 0.78);
  color: #71877b;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 34rpx;
}

.empty-copy {
  margin-top: 220rpx;
  width: 640rpx;
  white-space: pre-line;
  color: #8f877f;
  font-size: 40rpx;
  font-weight: 500;
  line-height: 66rpx;
}

.message-row {
  box-sizing: border-box;
  width: 100%;
  display: flex;
  flex-direction: column;
  margin-bottom: 15rpx;
  overflow: hidden;
}

.message-time {
  width: 100%;
  margin-top: 8rpx;
  margin-bottom: 15rpx;
  color: #a49a91;
  font-size: 19rpx;
  line-height: 31rpx;
  text-align: center;
}

.message-user {
  align-items: stretch;
}

.message-ai {
  align-items: stretch;
}

.message-bubble {
  max-width: 588rpx;
  border-radius: 35rpx;
  padding: 23rpx 27rpx;
  color: #2d2926;
  font-size: 25rpx;
  line-height: 42rpx;
}

.message-user .message-bubble {
  align-self: flex-end;
  max-width: 527rpx;
  background: #71877b;
  color: #fffdf9;
}

.message-ai .message-bubble {
  align-self: flex-start;
  background: #fffdf9;
  color: #6d665f;
}

.message-highlight {
  display: inline-block;
  padding: 0 7rpx 2rpx;
  border-radius: 9rpx;
  background: rgba(231, 240, 234, 0.75);
  box-shadow: none;
  border-bottom: 0;
  color: #557369;
  font-weight: 800;
  line-height: 1.18;
  vertical-align: baseline;
}

.message-user .message-highlight {
  background: rgba(236, 243, 234, 0.2);
  box-shadow: none;
  border-bottom: 0;
  color: #f6e9c8;
}

.typing {
  margin-left: 0;
  margin-bottom: 15rpx;
  width: 96rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #fffdf9;
  color: #71877b;
  text-align: center;
  font-size: 32rpx;
  line-height: 44rpx;
}

.chat-bottom-anchor {
  height: 52rpx;
}

.chat-input {
  position: fixed;
  left: 35rpx;
  right: 34rpx;
  height: 104rpx;
  border-radius: 31rpx;
  background: #fffdf9;
  z-index: 12;
}

.chat-input input {
  position: absolute;
  left: 38rpx;
  top: 33rpx;
  width: 452rpx;
  height: 38rpx;
  color: #6d665f;
  font-size: 25rpx;
}

.chat-input button {
  position: absolute;
  right: 19rpx;
  top: 13rpx;
  width: 104rpx;
  height: 77rpx;
  border-radius: 31rpx;
  background: #71877b;
  color: #fffdf9;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 77rpx;
}

.chat-input button[disabled] {
  background: #d8d1c9;
}
