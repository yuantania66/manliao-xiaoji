<view class="page note-history-page">
  <navigator url="/pages/note/note" class="back history-back" style="top: {{backTop}}px;" hover-class="none">‹ 返回</navigator>
  <navigator url="/pages/note/note" class="add-link" hover-class="none">+ 记一下</navigator>
  <view class="title">我的小记</view>
  <view class="body intro">{{introText}}</view>
  <view class="search-box">⌕<input value="{{query}}" bindinput="onInput" placeholder="查找小记内容" /></view>
  <view wx:if="{{statusText}}" class="history-status">{{statusText}}</view>
  <navigator url="/pages/note-calendar/note-calendar" class="calendar-entry card-sage" hover-class="none">
    <view class="entry-title">心情日历</view>
    <view class="entry-copy">按天气回看某一天</view>
    <view class="entry-arrow">›</view>
  </navigator>
  <view wx:if="{{isEmpty}}" class="empty body">还没有小记。先给今天留一句话。</view>
  <view wx:for="{{notes}}" wx:key="id" class="note-item">
    <navigator url="/pages/note-detail/note-detail?id={{item.id}}&date={{item.dateKey}}" hover-class="none">
      <view class="note-date">{{item.dateLabel}}</view>
      <view class="note-title">{{item.title}}</view>
      <view class="note-body">{{item.content}}</view>
      <view wx:if="{{item.mood}}" class="note-mood">{{item.mood.name}} · {{item.mood.desc}}</view>
    </navigator>
  </view>
</view>
