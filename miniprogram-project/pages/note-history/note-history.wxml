<view class="screen history-screen">
  <view class="status">9:41</view>
  <button class="back-link" bindtap="goBack">‹ 返回</button>
  <button class="add-note sage" bindtap="goNote">+ 记一下</button>
  <text class="history-title">我的小记</text>
  <text class="history-lead body-copy">按时间回看文字、图片和视频，不用一次看完。</text>
  <view class="search card">
    <text class="search-icon sage">⌕</text>
    <input class="search-input" value="{{searchQuery}}" placeholder="查找小记内容" bindinput="updateSearch" />
  </view>
  <view class="calendar-card">
    <text class="calendar-title">心情日历</text>
    <text class="calendar-copy sage">{{calendarSummary}}</text>
    <text class="arrow">›</text>
  </view>
  <text wx:if="{{filteredNotes.length > 0}}" class="month sage">我的记录</text>
  <block wx:for="{{filteredNotes}}" wx:key="id">
    <view class="entry" style="top: {{item.top}}px;" data-id="{{item.id}}" bindtap="openNote">
      <text class="entry-date muted">{{item.dateLabel}}</text>
      <text class="entry-title">{{item.moodName || '小记'}}</text>
      <text class="entry-body body-copy">{{item.preview}}</text>
    </view>
  </block>
  <text wx:if="{{loading}}" class="empty muted">正在加载小记...</text>
  <text wx:if="{{!loading && filteredNotes.length === 0}}" class="empty muted">没找到相关小记。</text>
  <view class="bottom-indicator"></view>
</view>
