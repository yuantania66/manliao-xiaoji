.note-detail-page {
  position: relative;
  padding-top: 122rpx;
  padding-bottom: 76rpx;
}

.detail-back {
  position: fixed;
  left: 42rpx;
  top: 96rpx;
  z-index: 25;
}

.detail-actions {
  position: relative;
  z-index: 9;
}

.detail-menu-button {
  position: fixed;
  right: 42rpx;
  top: 188rpx;
  z-index: 12;
  width: 77rpx;
  height: 42rpx;
  color: #71877b;
  font-size: 35rpx;
  font-weight: 700;
  line-height: 42rpx;
  text-align: center;
}

.menu-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10;
  background: rgba(251, 247, 240, 0.58);
}

.detail-menu {
  position: fixed;
  right: 42rpx;
  top: 250rpx;
  z-index: 13;
  width: 232rpx;
  min-height: 96rpx;
  border-radius: 30rpx;
  background: rgba(255, 253, 249, 0.98);
  box-shadow: 0 18rpx 46rpx rgba(184, 175, 166, 0.18);
  padding: 18rpx 22rpx;
}

.delete-menu-item {
  display: flex;
  align-items: center;
  min-height: 60rpx;
  color: #b2776c;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 36rpx;
}

.delete-icon {
  position: relative;
  width: 28rpx;
  height: 34rpx;
  flex: 0 0 28rpx;
  margin-right: 18rpx;
}

.delete-icon-handle,
.delete-icon-lid,
.delete-icon-body {
  position: absolute;
  border-color: #b2776c;
}

.delete-icon-handle {
  left: 9rpx;
  top: 0;
  width: 10rpx;
  height: 5rpx;
  border-top: 3rpx solid #b2776c;
  border-radius: 6rpx;
}

.delete-icon-lid {
  left: 2rpx;
  top: 8rpx;
  width: 24rpx;
  border-top: 3rpx solid #b2776c;
}

.delete-icon-body {
  left: 5rpx;
  top: 14rpx;
  width: 18rpx;
  height: 16rpx;
  border: 3rpx solid #b2776c;
  border-top: 0;
  border-radius: 0 0 5rpx 5rpx;
}

.detail-content {
  margin-top: 54rpx;
}

.detail-date {
  color: #71877b;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.text-content {
  margin-top: 54rpx;
  color: #2d2926;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 56rpx;
  word-break: break-word;
}

.media-grid {
  display: grid;
  gap: 12rpx;
  margin-top: 44rpx;
}

.image-content {
  width: 100%;
  border-radius: 30rpx;
  overflow: hidden;
  background: #e8f0ea;
}

.media-grid-one {
  width: 466rpx;
  max-width: 100%;
}

.media-grid-one .image-content {
  height: 466rpx;
}

.media-grid-two {
  width: 450rpx;
  grid-template-columns: repeat(2, 1fr);
}

.media-grid-two .image-content {
  height: 219rpx;
}

.media-grid-four {
  width: 450rpx;
  grid-template-columns: repeat(2, 1fr);
}

.media-grid-four .image-content {
  height: 219rpx;
}

.media-grid-nine {
  grid-template-columns: repeat(3, 1fr);
}

.media-grid-nine .image-content {
  height: 204rpx;
}

.empty-content {
  margin-top: 80rpx;
  color: #a49a91;
  font-size: 28rpx;
  line-height: 44rpx;
}

.detail-divider {
  height: 1rpx;
  margin-top: 58rpx;
  background: #e5dbd1;
}

.detail-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 28rpx;
}

.mood-pill {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  max-width: 420rpx;
  color: #71877b;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.detail-time {
  color: #a49a91;
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: right;
}

.status-text {
  margin-top: 42rpx;
  color: #71877b;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 36rpx;
}

.empty {
  margin-top: 180rpx;
}
