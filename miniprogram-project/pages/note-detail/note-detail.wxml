<view class="page note-detail-page">
  <view class="back detail-back" style="top: {{backTop}}px;" bindtap="goBack">‹ 返回</view>

  <view wx:if="{{note}}" class="detail-actions">
    <view class="detail-menu-button" bindtap="toggleMenu">···</view>
    <view wx:if="{{isMenuOpen}}" class="menu-mask" bindtap="closeMenu"></view>
    <view wx:if="{{isMenuOpen}}" class="detail-menu">
      <view class="delete-menu-item" bindtap="deleteCurrentNote">
        <view class="delete-icon">
          <view class="delete-icon-handle"></view>
          <view class="delete-icon-lid"></view>
          <view class="delete-icon-body"></view>
        </view>
        <text>{{isDeleting ? "删除中" : "删除小记"}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{note}}" class="detail-content">
    <view class="detail-date">{{note.dateLabel}}</view>

    <view wx:if="{{note.hasText}}" class="text-content">{{note.content}}</view>

    <view wx:if="{{note.hasImages}}" class="media-grid {{note.imageGridClass}}">
      <image
        wx:for="{{note.images}}"
        wx:key="url"
        class="image-content"
        src="{{item.url}}"
        mode="aspectFill"
        bindtap="previewImage"
        data-url="{{item.url}}"
      />
    </view>

    <view wx:if="{{!note.hasText && !note.hasImages}}" class="empty-content">这条小记暂时没有内容。</view>

    <view class="detail-divider"></view>
    <view class="detail-meta">
      <view wx:if="{{note.hasMood}}" class="mood-pill">☼ {{note.mood.name}} · {{note.mood.desc}}</view>
      <view class="detail-time">{{note.dateLabel}}</view>
    </view>
  </view>

  <view wx:else class="body empty">{{statusText || "这条小记暂时找不到。"}}</view>
</view>
