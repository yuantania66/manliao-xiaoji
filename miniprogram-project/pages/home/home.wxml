<view class="page home-page" style="padding-top: {{pageTop}}px;">
  <view class="date">{{todayLabel}}</view>
  <view class="home-title">{{prompt.title}}</view>
  <view class="home-lead">{{prompt.lead}}</view>

  <view class="leaf" aria-hidden="true">
    <view class="leaf-circle"></view>
    <view class="leaf-stem"></view>
    <view class="leaf-one"></view>
    <view class="leaf-two"></view>
  </view>

  <view class="action-card warm" bindtap="goChat">
    <view class="action-title">聊聊</view>
    <view class="action-copy">{{chatCopy}}</view>
    <view class="action-link">慢慢说  ›</view>
  </view>

  <view class="action-card sage" bindtap="goNote">
    <view class="action-title">记一下</view>
    <view class="action-copy">{{noteCopy}}</view>
    <view class="action-link">写一点  ›</view>
  </view>

  <view class="bottom-bar {{activeTab === 'me' ? 'is-me' : 'is-home'}} {{switchingTab ? 'is-switching' : ''}}">
    <view class="bottom-indicator"></view>
    <button class="bottom-item {{activeTab === 'home' ? 'active' : ''}}" data-tab="home" bindtap="switchTab">此刻</button>
    <button class="bottom-item {{activeTab === 'me' ? 'active' : ''}}" data-tab="me" bindtap="switchTab">我的</button>
  </view>

  <view wx:if="{{showEntry}}" class="entry-layer">
    <view class="entry-mask"></view>
    <view class="entry-sheet" style="bottom: {{entryBottom}}px;">
      <view class="entry-title">欢迎来到慢聊小记</view>
      <view class="entry-copy">登录后可以同步记录，也可以先用游客模式体验。</view>
      <view wx:if="{{entryError}}" class="entry-error">{{entryError}}</view>
      <button class="primary-button" disabled="{{isLoggingIn}}" bindtap="handleLogin">{{isLoggingIn ? "登录中..." : "登录"}}</button>
      <button class="guest-text" bindtap="enterGuest">游客模式</button>
    </view>
  </view>
</view>
